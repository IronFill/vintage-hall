---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout title="404 — Vintage Hall">
  <Header />
  <main class="mx-auto max-w-[1320px] px-4 py-[100px] text-center sm:px-6 md:px-8">
    <div class="mono mb-5 text-[64px] text-brass-light opacity-30">404</div>
    <h1 class="mb-3 font-display text-[2.375rem]">Сторінку не знайдено</h1>
    <p class="mb-7 text-[15px] text-sage">Можливо, цей лот вже продано, або посилання застаріло.</p>
    <a href="/" class="btn btn-primary">На головну</a>
  </main>
  <SiteFooter />
</Layout>
