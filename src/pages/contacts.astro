---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Overlays from '../components/Overlays.astro';

const mapEmbedUrl = 'https://www.openstreetmap.org/export/embed.html?bbox=30.49%2C50.50%2C30.51%2C50.52&layer=mapnik&marker=50.512%2C30.499';
---

<Layout
  title="Контакти — Vintage Hall"
  description="Контакти аукціонного дому Vintage Hall: адреса шоуруму на Андріївському узвозі, логістичний склад, графік роботи та способи зв'язку."
>
  <Header />
  <main class="mx-auto max-w-[1320px] px-4 py-12 sm:px-6 md:px-8 md:py-[60px]">
    <div class="mb-[22px] flex items-center gap-2.5 text-[0.875rem] uppercase tracking-[0.2em] text-brass"><span class="h-px w-8 bg-brass"></span> Контакти</div>
    <h1 class="mb-4 font-display text-[1.75rem] sm:text-[2.375rem]">Завжди раді бачити вас — особисто чи онлайн</h1>
    <p class="mb-12 max-w-[680px] text-base text-sage">Шоурум для перегляду лотів перед торгами, склад для зберігання та пакування, і команда підтримки, що відповідає щодня. Оберіть зручний спосіб зв'язку нижче.</p>

    <!-- Quick contact methods -->
    <div class="mb-14 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-vh border border-line bg-bg-card p-5 transition-colors hover:border-brass">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3 w-6 text-brass-light"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <div class="mb-1 font-display text-[1.0625rem] text-ivory">Телефон підтримки</div>
        <a href="tel:+380443921784" class="mono text-[0.9375rem] text-brass-light hover:underline">+380 44 392 17 84</a>
        <div class="mt-1 text-[0.8125rem] text-sage">Пн–Сб, 09:00–19:00</div>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-5 transition-colors hover:border-brass">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3 w-6 text-brass-light"><path d="M4 4h16v16H4z"/><path d="M22 6 12 13 2 6"/></svg>
        <div class="mb-1 font-display text-[1.0625rem] text-ivory">Електронна пошта</div>
        <a href="mailto:hello@vintagehall.com" class="mono text-[0.9375rem] text-brass-light hover:underline">hello@vintagehall.com</a>
        <div class="mt-1 text-[0.8125rem] text-sage">Відповідаємо протягом дня</div>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-5 transition-colors hover:border-brass">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3 w-6 text-brass-light"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        <div class="mb-1 font-display text-[1.0625rem] text-ivory">Telegram / чат на сайті</div>
        <span class="mono text-[0.9375rem] text-ivory/85">@vintagehall_support</span>
        <div class="mt-1 text-[0.8125rem] text-sage">Швидші відповіді під час торгів</div>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-5 transition-colors hover:border-brass">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3 w-6 text-brass-light"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        <div class="mb-1 font-display text-[1.0625rem] text-ivory">Графік роботи</div>
        <div class="text-[0.9375rem] text-ivory/85">Пн–Сб 09:00–19:00</div>
        <div class="mt-1 text-[0.8125rem] text-sage">Нд — лише онлайн-підтримка</div>
      </div>
    </div>

    <div class="my-12 h-px bg-line md:my-[60px]"></div>

    <!-- Two locations: showroom + warehouse -->
    <h2 class="mb-8 font-display text-[1.75rem]">Наші адреси</h2>
    <div class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div class="rounded-vh border border-line bg-bg-card p-7">
        <div class="mb-3 flex items-center gap-2.5 text-[0.78125rem] uppercase tracking-[0.12em] text-brass">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="w-4"><path d="M12 21s7-6.4 7-12a7 7 0 1 0-14 0c0 5.6 7 12 7 12Z"/><circle cx="12" cy="9" r="2.6"/></svg>
          Шоурум і виставкова зала
        </div>
        <h3 class="mb-2 font-display text-[1.25rem] text-ivory">Андріївський узвіз, 34, Київ</h3>
        <p class="mb-4 text-[0.9375rem] leading-[1.6] text-sage">Невелика експозиційна зала на історичній «вулиці антикварів» Києва — тут можна особисто оглянути обрані лоти перед аукціоном, проконсультуватися з експертом і забрати виграну річ без доставки. Вхід з боку внутрішнього дворика, домофон «Vintage Hall».</p>
        <ul class="space-y-1.5 text-[0.875rem] text-ivory/80">
          <li>· Перегляд лотів — за попереднім записом через чат або телефон</li>
          <li>· Найближче метро: Контрактова площа (12–15 хв пішки)</li>
          <li>· Самовивіз виграних лотів: Пн–Сб 10:00–18:00</li>
        </ul>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-7">
        <div class="mb-3 flex items-center gap-2.5 text-[0.78125rem] uppercase tracking-[0.12em] text-brass">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="w-4"><rect x="3" y="7" width="18" height="13" rx="1.5"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          Логістичний склад
        </div>
        <h3 class="mb-2 font-display text-[1.25rem] text-ivory">вул. Промислова, 12, Київ</h3>
        <p class="mb-4 text-[0.9375rem] leading-[1.6] text-sage">Тут зберігаються лоти, прийняті на комісію, відбувається фотозйомка для каталогу, експертна оцінка стану та пакування перед відправкою Новою поштою. Склад не призначений для відвідувань без попередньої домовленості — це робоча зона, а не виставкова.</p>
        <ul class="space-y-1.5 text-[0.875rem] text-ivory/80">
          <li>· Приймання лотів від продавців — за графіком, узгодженим індивідуально</li>
          <li>· Контрольована температура та вологість для делікатних матеріалів</li>
          <li>· Відправка Новою поштою — щодня до 17:00</li>
        </ul>
        <div class="mt-5 overflow-hidden rounded-vh border border-line">
          <iframe
            src={mapEmbedUrl}
            width="100%"
            height="240"
            style="border:0; display:block; filter:saturate(0.85);"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Карта: склад Vintage Hall, вул. Промислова 12, Київ"
          ></iframe>
        </div>
      </div>
    </div>

    <div class="rounded-vh border border-dashed border-line bg-accent-tint p-6 text-[0.8125rem] leading-[1.6] text-sage">
      Адреси та контакти на цій сторінці — демонстраційні дані для презентаційної версії платформи Vintage Hall і не належать чинній компанії.
    </div>
  </main>
  <SiteFooter />
  <Overlays />
  <script src="../scripts/app.ts"></script>
</Layout>
