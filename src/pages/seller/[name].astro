---
import Layout from '../../layouts/Layout.astro';
import LiteHeader from '../../components/LiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { SEEDED_PRODUCTS, PRODUCT_I18N, SELLERS } from '../../data/products';
import type { Product } from '../../types';

export function getStaticPaths() {
  return Object.keys(SELLERS).map((name) => ({
    params: { name },
    props: { name, info: SELLERS[name], lots: SEEDED_PRODUCTS.filter(p => p.seller === name) },
  }));
}

const { name, info, lots } = Astro.props as { name: string; info: typeof SELLERS[string]; lots: Product[] };

// Aggregate reviews across all of this seller's lots — a real seller-level reputation signal
// computed from actual per-lot review data, not a separate invented number.
const allReviews = lots.flatMap(p => (p.reviews ?? []).map(r => ({ ...r, lotName: PRODUCT_I18N[p.id]?.uk.name ?? '' })));
const avgLotReviewRating = allReviews.length ? allReviews.reduce((s, r) => s + r.rating, 0) / allReviews.length : null;

const title = `${name} — продавець на Vintage Hall`;
const description = `${name}: ${info.salesCount} продажів, рейтинг ${info.rating.toFixed(1)} ★, на платформі з ${2026 - info.yearsActive} року. ${lots.length} активних лотів.`;
---

<Layout title={title} description={description} ogType="profile">
  <LiteHeader />
  <main class="mx-auto max-w-[1320px] px-4 py-12 sm:px-6 md:px-8 md:py-[60px]">
    <div class="mb-[22px] flex items-center gap-2.5 text-[0.875rem] uppercase tracking-[0.2em] text-brass"><span class="h-px w-8 bg-brass"></span> Продавець</div>

    <div class="mb-10 flex flex-col items-start gap-5 sm:flex-row sm:items-center">
      <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full bg-brass font-mono text-xl font-semibold text-on-accent">
        {name.slice(0, 2).toUpperCase()}
      </div>
      <div>
        <h1 class="font-display text-[1.75rem] sm:text-[2.375rem]">{name}{info.verified && ' ✓'}</h1>
        <p class="mono mt-1 text-[0.9375rem] text-brass-light">★ {info.rating.toFixed(1)} · {info.salesCount} продажів · на платформі з {2026 - info.yearsActive}</p>
      </div>
    </div>

    <div class="mb-10 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-vh border border-line bg-bg-card p-4 text-center">
        <div class="mono text-xl text-brass-light">{info.salesCount}</div>
        <div class="mt-1 text-[0.78125rem] text-sage">продажів</div>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-4 text-center">
        <div class="mono text-xl text-brass-light">{2026 - info.yearsActive}</div>
        <div class="mt-1 text-[0.78125rem] text-sage">на платформі з</div>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-4 text-center">
        <div class="mono text-xl text-brass-light">{Math.round((info.rating / 5) * 100)}%</div>
        <div class="mt-1 text-[0.78125rem] text-sage">позитивних відгуків</div>
      </div>
      <div class="rounded-vh border border-line bg-bg-card p-4 text-center">
        <div class="mono text-xl text-brass-light">{lots.length}</div>
        <div class="mt-1 text-[0.78125rem] text-sage">активних лотів</div>
      </div>
    </div>

    <h2 class="mb-5 font-display text-2xl text-ivory">Усі лоти продавця</h2>
    <div class="seller-lots-grid">
      {lots.map((p, i) => {
        const tr = PRODUCT_I18N[p.id]?.uk;
        const price = p.saleType === 'auction' ? (p.currentBid ?? p.startPrice ?? 0) : (p.price ?? 0);
        return (
          <a class="category-card" href={`/lot/${p.id}`}>
            <div class="category-card-media">
              {p.photo ? <img src={p.photo} alt={tr?.name ?? ''} loading={i < 4 ? 'eager' : 'lazy'} /> : <div class="category-card-empty">VH</div>}
            </div>
            <div class="category-card-name">{tr?.name}</div>
            <div class="category-card-price mono">{price.toLocaleString('uk-UA')} ₴</div>
          </a>
        );
      })}
    </div>

    {allReviews.length > 0 && (
      <section class="mt-12 max-w-[640px]">
        <div class="mb-3.5 flex items-baseline gap-2">
          <h2 class="font-display text-2xl text-ivory">Відгуки про продавця</h2>
          {avgLotReviewRating && <span class="mono text-brass-light">★ {avgLotReviewRating.toFixed(1)} ({allReviews.length})</span>}
        </div>
        <div class="reviews-list">
          {allReviews.map(r => (
            <div class="review-row">
              <div class="review-row-head"><span>{r.author} <span class="text-sage">· {r.lotName}</span></span><span class="mono" style="color:var(--brass-light);">{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</span></div>
              <div class="review-row-date mono">{r.date}</div>
              <p>{r.text}</p>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
  <SiteFooter />
</Layout>

<style>
  .seller-lots-grid{display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:18px;}
  .category-card{display:block; background:var(--bg-card); border:1px solid var(--line); border-radius:var(--radius); overflow:hidden; transition:border-color .2s, transform .2s;}
  .category-card:hover{border-color:var(--brass); transform:translateY(-2px);}
  .category-card-media{aspect-ratio:4/3; overflow:hidden;}
  .category-card-media img{width:100%; height:100%; object-fit:cover; display:block;}
  .category-card-empty{width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-family:'Cormorant',serif; font-size:1.75rem; color:var(--brass-light); background:var(--accent-tint);}
  .category-card-name{padding:10px 12px 2px; font-size:0.875rem; color:var(--ivory);}
  .category-card-price{padding:0 12px 12px; font-size:0.8125rem; color:var(--brass-light);}
</style>
