---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustSection from '../components/TrustSection.astro';
import LiveAuctions from '../components/LiveAuctions.astro';
import Collections from '../components/Collections.astro';
import HowItWorks from '../components/HowItWorks.astro';
import SafetySection from '../components/SafetySection.astro';
import Sidebar from '../components/Sidebar.astro';
import CatalogSection from '../components/CatalogSection.astro';
import ExpertiseSection from '../components/ExpertiseSection.astro';
import AboutSection from '../components/AboutSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Overlays from '../components/Overlays.astro';
---

<Layout>
  <Header />
  <Hero />
  <div class="mx-auto max-w-[1320px] px-4 sm:px-6 md:px-8">
    <TrustSection />
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <LiveAuctions />
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <Collections />
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <div class="grid grid-cols-1 items-start gap-[18px] md:grid-cols-[220px_1fr] md:gap-9">
      <Sidebar />
      <CatalogSection />
    </div>
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <SafetySection />
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <HowItWorks />
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <ExpertiseSection />
    <div class="my-12 h-px bg-line md:my-[70px]"></div>
    <AboutSection />
  </div>
  <SiteFooter />
  <Overlays />
  <script src="../scripts/app.ts"></script>
</Layout>
