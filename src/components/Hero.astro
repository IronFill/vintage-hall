---
import { SEEDED_PRODUCTS, PRODUCT_I18N } from '../data/products';

const featuredIds = [2, 7, 12, 10] as const;
const featured = featuredIds.map((id) => {
  const p = SEEDED_PRODUCTS.find((x) => x.id === id)!;
  const name = PRODUCT_I18N[id]?.uk?.name ?? '';
  const price = p.saleType === 'auction' ? (p.currentBid ?? p.startPrice ?? 0) : (p.price ?? 0);
  return {
    id: p.id,
    name,
    photo: p.photo ?? '',
    saleType: p.saleType,
    price,
    endTime: p.endTime ?? null,
  };
});
---

<section class="hero">
  <div class="hero-editorial-left">
    <div class="eyebrow-editorial">
      <span id="heroEyebrow">Осінні торги 2026</span>
    </div>
    <h1 id="heroH1">Предмети з <em>характером</em><br>та гарантією справжності</h1>
    <div class="hero-rule"></div>
    <p id="heroP" class="hero-sub">Аукціонний дім та маркетплейс антикваріату. 48 верифікованих продавців, понад 2 800 угод.</p>
    <div class="hero-actions">
      <a href="#live-auctions" class="btn btn-primary" id="btnViewAuctions">Переглянути каталог</a>
      <button class="btn btn-ghost" id="heroSellBtn">Продати предмет</button>
    </div>
    <div class="hero-quick-links">
      <a href="/expertise" class="hero-quick-link">
        <svg class="hero-ql-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/>
        </svg>
        Запит до експерта
      </a>
      <a href="/forum" class="hero-quick-link">
        <svg class="hero-ql-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Спільнота
      </a>
      <button class="hero-quick-link" id="heroSearchTriggerBtn">
        <svg class="hero-ql-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
        Пошук лотів
      </button>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="mono hero-stat-num" id="heroLotCount">11</span>
        <span class="hero-stat-lbl" id="heroLotLabel">лотів</span>
      </div>
      <div class="hero-stat-sep"></div>
      <div class="hero-stat">
        <span class="mono hero-stat-num">48</span>
        <span class="hero-stat-lbl" id="heroSellersLabel">продавців</span>
      </div>
      <div class="hero-stat-sep"></div>
      <div class="hero-stat">
        <span class="mono hero-stat-num">312</span>
        <span class="hero-stat-lbl" id="heroSoldLabel">продано</span>
      </div>
    </div>
  </div>

  <div class="hero-lot-col">
    <div class="hero-lot-stamp" id="heroStamp">СПРАВЖНІСТЬ<br>ГАРАНТОВАНА</div>
    <a class="hero-lot-card" id="heroLotCard" href={`/lot/${featured[0].id}`} aria-label="Перейти до топ-лоту">
      <div class="hero-lot-badge">★ Топ-лот тижня</div>
      <div class="hero-lot-num" id="heroLotNum">ЛОТ-002</div>
      <div class="hero-lot-photo"><img id="heroLotImg" src={featured[0].photo} alt="" /></div>
      <div class="hero-lot-body">
        <div class="hero-lot-name" id="heroLotName">{featured[0].name}</div>
        <div class="hero-lot-meta" id="heroLotMeta">Антикваріат · XIX ст.</div>
        <div class="hero-lot-price-row">
          <span class="hero-lot-price mono" id="heroLotPrice"></span>
          <span class="hero-lot-timer mono" id="heroLotTimer"></span>
        </div>
      </div>
      <div class="hero-lot-footer">
        <span class="hero-lot-cta" id="heroLotCta">Зробити ставку</span>
        <span class="hero-lot-arrow">→</span>
      </div>
    </a>
    <div class="hero-lot-dots" id="heroLotDots">
      {featured.map((_, i) => (
        <span class={`hero-lot-dot ${i === 0 ? 'active' : ''}`} data-idx={i}></span>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ featured }}>
  let heroLotIdx = 0;

  function heroFmtPrice(v) {
    return v ? v.toLocaleString('ru-RU') + ' ₴' : '';
  }

  function heroUpdateTimer() {
    const f = featured[heroLotIdx];
    const el = document.getElementById('heroLotTimer');
    if (!el) return;
    if (!f.endTime) { el.textContent = ''; return; }
    const diff = new Date(f.endTime).getTime() - Date.now();
    if (diff <= 0) { el.textContent = 'Торги завершено'; return; }
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    el.textContent = `⏱ ${h}г ${m}хв ${s}с`;
  }

  function heroRenderLot(animate) {
    const card = document.getElementById('heroLotCard');
    const apply = () => {
      const f = featured[heroLotIdx];
      const img = document.getElementById('heroLotImg');
      const name = document.getElementById('heroLotName');
      const price = document.getElementById('heroLotPrice');
      const num = document.getElementById('heroLotNum');
      const cta = document.getElementById('heroLotCta');
      if (card) card.setAttribute('href', `/lot/${f.id}`);
      if (img) img.setAttribute('src', f.photo);
      if (name) name.textContent = f.name;
      if (num) num.textContent = `ЛОТ-0${f.id.toString().padStart(2,'0')}`;
      if (price) price.textContent = f.saleType === 'auction' ? `Ставка: ${heroFmtPrice(f.price)}` : heroFmtPrice(f.price);
      if (cta) cta.textContent = f.saleType === 'auction' ? 'Зробити ставку' : 'Переглянути лот';
      document.querySelectorAll('#heroLotDots .hero-lot-dot').forEach((d, i) => d.classList.toggle('active', i === heroLotIdx));
      heroUpdateTimer();
    };
    if (animate && card) {
      card.classList.add('hero-lot-fade');
      setTimeout(() => {
        apply();
        requestAnimationFrame(() => card.classList.remove('hero-lot-fade'));
      }, 220);
    } else {
      apply();
    }
  }

  document.querySelectorAll('#heroLotDots .hero-lot-dot').forEach((d) => {
    d.addEventListener('click', (e) => {
      e.preventDefault();
      heroLotIdx = parseInt(d.getAttribute('data-idx') ?? '0', 10);
      heroRenderLot(true);
    });
  });

  heroRenderLot(false);
  setInterval(heroUpdateTimer, 1000);
  setInterval(() => { heroLotIdx = (heroLotIdx + 1) % featured.length; heroRenderLot(true); }, 5000);

  document.getElementById('heroSearchTriggerBtn')?.addEventListener('click', () => {
    const si = document.getElementById('searchInput');
    if (si) {
      si.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(() => si.focus(), 450);
    }
  });
</script>
