<section class="relative z-[1] py-12 md:py-[70px]" id="catalog">
  <div class="mb-8 flex flex-col items-start gap-1.5 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between sm:gap-4 md:mb-[42px]">
    <h2 class="text-[1.875rem] text-ivory" id="catalogTitle">Каталог лотів</h2>
    <div class="flex items-center gap-4">
      <span class="mono text-[0.9375rem] text-sage" id="lotCount">11 лотів</span>
      <button class="btn btn-primary" id="addLotBtn" style="font-size:13px; padding:9px 18px;">+ <span id="addLotBtnLabel">Виставити лот</span></button>
    </div>
  </div>
  <div class="mode-toggle mb-5 w-max md:mb-[22px]" id="modeToggle">
    <button class="active" data-mode="all"><span id="modeAllLabel">Усі лоти</span></button>
    <button data-mode="shop"><span id="modeShopLabel">Магазин</span></button>
    <button data-mode="auction"><span id="modeAuctionLabel">Аукціон</span></button>
  </div>
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center md:mb-7">
    <div class="search-box flex-1 sm:min-w-[200px]">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input type="text" id="searchInput" placeholder="Пошук лотів..." />
    </div>
    <select class="sort-select" id="sortSelect">
      <option value="default">За замовчуванням</option>
      <option value="price-asc">Ціна: спочатку дешевші</option>
      <option value="price-desc">Ціна: спочатку дорожчі</option>
      <option value="new">Спочатку нові</option>
      <option value="ending-soon">Завершення скоро</option>
    </select>
  </div>
  <div class="mb-[18px] flex flex-wrap gap-2.5">
    <select id="filterOrigin">
      <option value="">— Походження —</option>
    </select>
    <select id="filterMaterial">
      <option value="">— Матеріал —</option>
    </select>
    <select id="filterRarity">
      <option value="">— Рідкість —</option>
      <option value="common">Поширений</option>
      <option value="rare">Рідкісний</option>
      <option value="unique">Унікальний</option>
    </select>
  </div>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-7" id="catalogGrid"></div>
</section>
