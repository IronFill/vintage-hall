<div class="topbar">
  <div class="topbar-inner">
    <div class="topbar-left">
      <span id="topbarTagline">Аукціонний дім антикваріату</span>
      <span class="topbar-sep">·</span>
      <span id="topbarHours">пн–пт 10:00–18:00</span>
    </div>
    <div class="topbar-right">
      <div class="lang-dots" id="langSwitch">
        <button data-lang="uk" class="active">UA</button>
        <span>·</span>
        <button data-lang="en">EN</button>
        <span>·</span>
        <button data-lang="pl">PL</button>
        <span>·</span>
        <button data-lang="ru">RU</button>
      </div>
    </div>
  </div>
</div>

<header>
  <div class="header-inner">
    <a href="/" class="logo" aria-label="Vintage Hall — на головну">
      <svg class="seal" width="32" height="32" viewBox="0 0 120 120" fill="none" stroke="currentColor" aria-hidden="true">
        <path d="M60 18 L98 36 L98 70 L60 100 L22 70 L22 36 Z" stroke-width="3.4"/>
        <path d="M60 26 L91 41 L91 67 L60 91 L29 67 L29 41 Z" stroke-width="1.4"/>
        <text x="60" y="66" font-family="Cormorant" font-size="30" fill="currentColor" stroke="none" text-anchor="middle">VH</text>
        <line x1="40" y1="78" x2="80" y2="78" stroke-width="1.6"/>
      </svg>
      <div class="logo-text">
        <span class="word" id="logoWord">Vintage Hall</span>
        <span class="logo-founded" id="logoFounded">Засновано 2019 · Київ</span>
      </div>
    </a>

    <nav class="hidden xl:flex" aria-label="Основна навігація">
      <a href="/catalog" id="navCatalog">Каталог</a>
      <span class="nav-sep" aria-hidden="true"></span>
      <a href="/#live-auctions" id="navAuctions">Аукціони</a>
      <span class="nav-sep" aria-hidden="true"></span>
      <a href="/news" id="navNews">Новини</a>
      <span class="nav-sep" aria-hidden="true"></span>
      <a href="/about" id="navAbout">Про нас</a>
      <span class="nav-sep" aria-hidden="true"></span>
      <a href="/contacts" id="navContacts">Контакти</a>
    </nav>

    <div class="header-right">
      <form id="headerSearchForm" class="header-search hidden xl:flex" role="search" aria-label="Пошук по каталогу">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        <input type="text" id="headerSearchInput" placeholder="Пошук лотів..." aria-label="Пошук лотів">
      </form>

      <button class="theme-toggle" id="themeToggle" aria-label="Перемкнути тему">
        <svg id="themeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 12.4A9 9 0 1 1 11.6 3a7 7 0 0 0 9.4 9.4Z"/></svg>
      </button>

      <button class="cart-btn hidden md:flex" id="accountBtn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6"/></svg>
        <span id="accountBtnLabel">Кабінет</span>
      </button>

      <button class="cart-btn cart-btn-accent" id="cartOpenBtn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="hidden sm:inline" id="cartBtnLabel">Кошик</span>
        <span class="cart-count" id="cartCount">0</span>
      </button>

      <button class="hamburger-btn" id="sitemapBtn" aria-label="Меню" aria-expanded="false" aria-controls="sitemapPanel" title="Меню">
        <span></span>
        <span></span>
        <span class="short"></span>
      </button>
    </div>
  </div>
</header>

<div class="sitemap-overlay" id="sitemapOverlay"></div>
<aside class="sitemap-panel" id="sitemapPanel" role="dialog" aria-modal="true" aria-labelledby="sitemapTitle">
  <div class="sitemap-head">
    <h3 id="sitemapTitle">Навігація</h3>
    <button class="drawer-close" id="sitemapCloseBtn" aria-label="Закрити меню">&times;</button>
  </div>
  <nav class="sitemap-links">
    <a href="/catalog">Каталог</a>
    <a href="/#live-auctions">Активні аукціони</a>
    <a href="/news">Новини</a>
    <a href="/forum">Форум</a>
    <a href="/about">Про нас</a>
    <a href="/contacts">Контакти</a>
    <a href="/delivery">Доставка</a>
    <a href="/rules">Правила</a>
  </nav>
  <div class="sitemap-mobile-extra md:hidden">
    <div class="flex gap-1 pt-2" id="langSwitchMobile">
      <button data-lang="uk" class="active flex-1 rounded-vh border border-line py-2 font-mono text-[0.8125rem] text-sage">UA</button>
      <button data-lang="en" class="flex-1 rounded-vh border border-line py-2 font-mono text-[0.8125rem] text-sage">EN</button>
      <button data-lang="pl" class="flex-1 rounded-vh border border-line py-2 font-mono text-[0.8125rem] text-sage">PL</button>
      <button data-lang="ru" class="flex-1 rounded-vh border border-line py-2 font-mono text-[0.8125rem] text-sage">RU</button>
    </div>
    <button class="cart-btn mt-2 w-full justify-center" id="accountBtnMobile">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6"/></svg>
      <span>Кабінет</span>
    </button>
  </div>
</aside>
