# Copy this file to .env and fill in your real values.
# Anything left blank stays disabled — no fake/placeholder tracking or backend calls are made.

# --- Analytics (optional) ---
# Google Analytics 4 measurement ID (Admin → Data Streams → Web)
PUBLIC_GA_ID=

# Yandex Metrica counter ID (numeric, from metrika.yandex.ru)
PUBLIC_YM_COUNTER_ID=

# --- Supabase (optional, see src/lib/supabase.ts and supabase/schema.sql) ---
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_URL=

# anon/public API key (Settings → API). Safe to expose client-side — protected by RLS.
PUBLIC_SUPABASE_ANON_KEY=
